<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Covers EF.Packages (core) and EF.Packages.Enterprise — same org feed -->
    <add key="efreeman518-github" value="https://nuget.pkg.github.com/efreeman518/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="efreeman518-github">
      <!-- EF.* pattern covers all core and enterprise packages: EF.Domain, EF.Storage, EF.FlowEngine, EF.FilterBuilder, etc. -->
      <package pattern="EF.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
