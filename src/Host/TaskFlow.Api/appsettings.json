{
  "AppName": "TaskFlowApi",
  "AuthMode": "Scaffold",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "TaskFlowDbContextTrxn": "",
    "TaskFlowDbContextQuery": "",
    "Redis1": "",
    "BlobStorage1": "",
    "TableStorage1": "",
    "ServiceBus1": "",
    "CosmosDb1": ""
  },
  "EntraID": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "",
    "ClientId": ""
  },
  "AuditLogStorageSettings": {
    "TableName": "taskflowaudit",
    "NullTenantPartitionKey": "_system"
  },
  "BlobStorageSettings": {
    "ContainerName": "attachments"
  },
  "CacheSettings": [
    {
      "Name": "TaskFlowCache",
      "DurationMinutes": 30,
      "DistributedCacheDurationMinutes": 60,
      "FailSafeMaxDurationMinutes": 120,
      "FailSafeThrottleDurationSeconds": 1,
      "JitterMaxDurationSeconds": 10,
      "FactorySoftTimeoutSeconds": 1,
      "FactoryHardTimeoutSeconds": 30,
      "EagerRefreshThreshold": 0.9,
      "RedisConnectionStringName": "Redis1",
      "BackplaneChannelName": "taskflow-cache-sync"
    }
  ],
  "Database": {
    "Retry": {
      "MaxRetryCount": 5,
      "MaxRetryDelaySeconds": 30
    }
  },
  "FeatureFlags": {
    "EnableNotifications": false
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "RateLimiting": {
    "PerTenant": {
      "PermitLimit": 100,
      "WindowSeconds": 60
    }
  },
  "AiServices": {
    "UseSearch": false,
    "UseAgents": false,
    "UseVectorSearch": false,
    "FoundryEndpoint": "",
    "AgentModelDeployment": "gpt-4o-deploy",
    "EmbeddingModelDeployment": "embedding-deploy",
    "SearchEndpoint": "",
    "SearchIndexName": "taskitems-index"
  },
  "Cosmos": {
    "TaskViews": {
      "DatabaseName": "taskflow-db",
      "ContainerName": "task-views"
    }
  }
}
