{
  "AppName": "TaskFlowGateway",
  "AuthMode": "Scaffold",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Proxy": {
    "ForwardedHeaders": {
      "Enabled": false,
      "ForwardLimit": 1,
      "KnownProxies": [],
      "KnownNetworks": [],
      "AllowedHosts": []
    },
    "PathBase": ""
  },
  "CorsSettings": {
    "AllowedOrigins": [ "https://localhost:5002", "http://localhost:5002", "https://localhost:7069", "http://localhost:5189" ]
  },
  "AggregateHealthCheck": {
    "TaskFlowApiHealthUrl": "https+http://taskflowapi/health/full",
    "TaskFlowApiClusterId": "api-cluster",
    "TimeoutSeconds": 5
  },
  "RateLimiting": {
    "Health": {
      "MemoryPermitLimit": 30,
      "FullPermitLimit": 3
    }
  },
  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "api-cluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "api-cluster": {
        "Destinations": {
          "api": {
            "Address": "https+http://taskflowapi"
          }
        }
      }
    }
  }
}
