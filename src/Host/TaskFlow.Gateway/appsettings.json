{
  "AppName": "TaskFlowGateway",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "EntraExternal": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "",
    "ClientId": ""
  },
  "CorsSettings": {
    "AllowedOrigins": [ "https://localhost:5002", "http://localhost:5002", "https://localhost:7069", "http://localhost:5189" ]
  },
  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "api-cluster",
        "Match": {
          "Path": "api/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "api-cluster": {
        "Destinations": {
          "api": {
            "Address": "https+http://taskflowapi"
          }
        }
      }
    }
  }
}
