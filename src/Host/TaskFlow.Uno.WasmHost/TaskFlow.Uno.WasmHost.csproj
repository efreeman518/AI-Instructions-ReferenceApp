<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>TaskFlow.Uno.WasmHost</RootNamespace>
    <UnoWasmProject>$(MSBuildProjectDirectory)\..\..\UI\TaskFlow.Uno\TaskFlow.Uno.csproj</UnoWasmProject>
    <UnoWasmTargetFramework>net10.0-browserwasm</UnoWasmTargetFramework>
    <UnoWasmRestoreTimeoutMilliseconds Condition="'$(UnoWasmRestoreTimeoutMilliseconds)'==''">600000</UnoWasmRestoreTimeoutMilliseconds>
    <UnoWasmBuildTimeoutMilliseconds Condition="'$(UnoWasmBuildTimeoutMilliseconds)'==''">1200000</UnoWasmBuildTimeoutMilliseconds>
  </PropertyGroup>

  <Target Name="BuildTaskFlowUnoWasm"
          BeforeTargets="Build"
          Condition="'$(SkipUnoWasmBuild)'!='true' and ('$(SolutionDir)'=='' or '$(SolutionDir)'=='*Undefined*')">
    <PropertyGroup>
      <_UseMocksProperty Condition="'$(UseMocks)'!=''"> -p:UseMocks=$(UseMocks)</_UseMocksProperty>
    </PropertyGroup>
    <Exec Command="dotnet restore &quot;$(UnoWasmProject)&quot; -p:BuildAllUnoTargets=true -p:EnableUnoWasm=true -p:Configuration=$(Configuration)$(_UseMocksProperty)"
          Timeout="$(UnoWasmRestoreTimeoutMilliseconds)" />
    <Exec Command="dotnet build &quot;$(UnoWasmProject)&quot; -p:TargetFrameworkOverride=$(UnoWasmTargetFramework) -p:EnableUnoWasm=true -p:Configuration=$(Configuration)$(_UseMocksProperty) --no-restore -m:1"
          Timeout="$(UnoWasmBuildTimeoutMilliseconds)" />
  </Target>

</Project>
