@page "/tasks/new"
@page "/tasks/{Id:guid}"
@implements IDisposable
@inject FloatService FloatService
@inject ITaskFlowApiClient Api
@inject NavigationManager Nav
@inject IDialogService DialogService

<PageTitle>@(IsNew ? "New Task" : "Edit Task") - TaskFlow</PageTitle>

<div class="d-flex align-center mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo("/tasks"))" />
    <MudText Typo="Typo.h4" Class="ml-2">@(IsNew ? "New Task" : "Edit Task")</MudText>
    <MudSpacer />
    @if (!IsNew)
    {
        <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete"
                   OnClick="DeleteAsync" Disabled="@FloatService.RequestIsActive">Delete</MudButton>
    }
    <MudButton Class="ml-2" Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Save"
               OnClick="SaveAsync" Disabled="@FloatService.RequestIsActive">Save</MudButton>
</div>

@if (_model is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-4" Elevation="2">
                <MudTextField @bind-Value="_model.Title" Label="Title" Required="true" Variant="Variant.Outlined" Class="mb-3" />
                <MudTextField @bind-Value="_model.Description" Label="Description" Lines="4" Variant="Variant.Outlined" Class="mb-3" />

                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="TaskItemStatus" @bind-Value="_model.Status" Label="Status" Variant="Variant.Outlined">
                            @foreach (var s in Enum.GetValues<TaskItemStatus>().Where(s => s != TaskItemStatus.None))
                            {
                                <MudSelectItem Value="@s">@s</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="Priority" @bind-Value="_model.Priority" Label="Priority" Variant="Variant.Outlined">
                            @foreach (var p in Enum.GetValues<Priority>().Where(p => p != Priority.None))
                            {
                                <MudSelectItem Value="@p">@p</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker Date="@_startDate" DateChanged="@(d => _startDate = d)"
                                       Label="Start Date" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker Date="@_dueDate" DateChanged="@(d => _dueDate = d)"
                                       Label="Due Date" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="Guid?" Value="_model.CategoryId" ValueChanged="OnCategoryChanged"
                                   Label="Category" Clearable="true" Variant="Variant.Outlined">
                            @foreach (var c in _categories)
                            {
                                <MudSelectItem Value="@((Guid?)c.Id)">@c.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudNumericField @bind-Value="_model.EstimatedEffort" Label="Est. Effort" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudNumericField @bind-Value="_model.ActualEffort" Label="Actual Effort" Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudExpansionPanels Class="mt-4" MultiExpansion="true">
                <MudExpansionPanel Text="@($"Checklist ({Checklist.Count})")" Expanded="@(!IsNew)">
                    <div class="d-flex align-center mb-2">
                        <MudTextField @bind-Value="_newChecklistTitle" Placeholder="Add item..." Variant="Variant.Outlined"
                                      Margin="Margin.Dense" Immediate="true"
                                      OnKeyDown="@(e => { if (e.Key == "Enter") AddChecklist(); })" />
                        <MudButton Class="ml-2" Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="AddChecklist">Add</MudButton>
                    </div>
                    @foreach (var item in Checklist)
                    {
                        <div class="d-flex align-center">
                            <MudCheckBox T="bool" Value="@item.IsCompleted"
                                         ValueChanged="@(v => ToggleChecklist(item, v))" />
                            <MudText Class="@(item.IsCompleted ? "mud-text-disabled" : "")">@item.Title</MudText>
                            <MudSpacer />
                            <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                           OnClick="@(() => DeleteChecklist(item))" />
                        </div>
                    }
                    @if (Checklist.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">No checklist items yet.</MudText>
                    }
                </MudExpansionPanel>
                <MudExpansionPanel Text="@($"Comments ({Comments.Count})")" Expanded="@(!IsNew)">
                    <div class="d-flex align-start mb-2">
                        <MudTextField @bind-Value="_newCommentBody" Placeholder="Add a comment..."
                                      Variant="Variant.Outlined" Lines="2" />
                        <MudButton Class="ml-2 mt-1" Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="AddComment">Add</MudButton>
                    </div>
                    @foreach (var c in Comments)
                    {
                        <MudPaper Class="pa-2 mb-1" Elevation="0" Outlined="true">
                            <div class="d-flex align-start">
                                <MudText Typo="Typo.body2" Style="flex: 1; white-space: pre-wrap;">@c.Body</MudText>
                                <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                               OnClick="@(() => DeleteComment(c))" />
                            </div>
                        </MudPaper>
                    }
                    @if (Comments.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">No comments yet.</MudText>
                    }
                </MudExpansionPanel>
            </MudExpansionPanels>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.subtitle1">Info</MudText>
                <MudDivider Class="my-2" />
                <MudText Typo="Typo.body2">ID: @(_model.Id?.ToString() ?? "(new)")</MudText>
                <MudText Typo="Typo.body2">Category: @(_selectedCategoryName ?? "-")</MudText>
                @if (_model.CompletedDate is not null)
                {
                    <MudText Typo="Typo.body2">Completed: @_model.CompletedDate.Value.LocalDateTime</MudText>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool IsNew => Id is null;
    private TaskItemDto? _model;
    private TaskItemDto? _baseline;
    private DateTime? _baselineStart;
    private DateTime? _baselineDue;
    private DateTime? _startDate;
    private DateTime? _dueDate;
    private List<CategoryDto> _categories = new();
    private string? _newChecklistTitle;
    private string? _newCommentBody;
    private string? _selectedCategoryName;
    private IDisposable? _locationChangingRegistration;
    private bool _bypassDirtyCheck;
    private bool _childrenDirty;

    // The Updater on the server handles child-collection syncing on Create and Update,
    // so the UI treats ChecklistItems / Comments as local state attached to the parent
    // DTO and persists them in the single Save call.
    private List<ChecklistItemDto> Checklist => _model!.ChecklistItems ??= new();
    private List<CommentDto> Comments => _model!.Comments ??= new();

    protected override void OnInitialized()
    {
        // MudNavLink rendered anchors navigate via the Blazor Router. Without
        // this hook a click on the top-menu silently discards any in-flight
        // edits on this page. LocationChanging lets us cancel the nav and
        // prompt first, then re-issue the navigation if the user confirms.
        _locationChangingRegistration = Nav.RegisterLocationChangingHandler(OnLocationChangingAsync);
    }

    protected override async Task OnParametersSetAsync()
    {
        FloatService.ModuleName = IsNew ? "Tasks / New" : "Tasks / Edit";
        await LoadCategoriesAsync();
        if (IsNew)
        {
            _model = new TaskItemDto
            {
                Title = string.Empty,
                Status = TaskItemStatus.Open,
                Priority = Priority.Medium,
                ChecklistItems = new(),
                Comments = new()
            };
            _startDate = null;
            _dueDate = null;
        }
        else
        {
            await LoadTaskAsync(Id!.Value);
        }
        CaptureBaseline();
        _bypassDirtyCheck = false;
    }

    private async Task LoadCategoriesAsync()
    {
        var result = await FloatService.ExecuteWithProgressAsync(
            () => Api.SearchCategoriesAsync(new SearchRequest<CategorySearchFilter>
            {
                Filter = new CategorySearchFilter { IsActive = true },
                PageSize = 200
            }), "Failed to load categories.");
        _categories = result?.Data?.ToList() ?? new();
    }

    private async Task LoadTaskAsync(Guid id)
    {
        var result = await FloatService.ExecuteWithProgressAsync(
            () => Api.GetTaskItemAsync(id), "Failed to load task.");
        if (result?.Item is null)
        {
            FloatService.ShowSnack("Task not found.", Severity.Warning);
            Nav.NavigateTo("/tasks");
            return;
        }
        _model = result.Item;
        _model.ChecklistItems = _model.ChecklistItems?.OrderBy(c => c.SortOrder).ToList() ?? new();
        _model.Comments ??= new();
        _startDate = _model.StartDate?.LocalDateTime;
        _dueDate = _model.DueDate?.LocalDateTime;
        _selectedCategoryName = _categories.FirstOrDefault(c => c.Id == _model.CategoryId)?.Name;
    }

    private void OnCategoryChanged(Guid? value)
    {
        if (_model is null) return;
        _model.CategoryId = value;
        _selectedCategoryName = _categories.FirstOrDefault(c => c.Id == value)?.Name;
    }

    private async Task SaveAsync()
    {
        if (_model is null) return;
        if (string.IsNullOrWhiteSpace(_model.Title))
        {
            FloatService.ShowSnack("Title is required.", Severity.Warning);
            return;
        }

        _model.StartDate = _startDate.HasValue ? new DateTimeOffset(_startDate.Value) : null;
        _model.DueDate = _dueDate.HasValue ? new DateTimeOffset(_dueDate.Value) : null;

        if (IsNew)
        {
            var resp = await FloatService.ExecuteWithProgressAsync(
                () => Api.CreateTaskItemAsync(new DefaultRequest<TaskItemDto> { Item = _model }),
                "Failed to create task.");
            if (resp?.Item?.Id is Guid newId)
            {
                FloatService.ShowSnack("Task created.", Severity.Success);
                FloatService.NotifyTaskItemsChanged();
                _bypassDirtyCheck = true;
                Nav.NavigateTo($"/tasks/{newId}");
            }
        }
        else
        {
            var resp = await FloatService.ExecuteWithProgressAsync(
                () => Api.UpdateTaskItemAsync(_model.Id!.Value,
                    new DefaultRequest<TaskItemDto> { Item = _model }),
                "Failed to update task.");
            if (resp?.Item is not null)
            {
                _model = resp.Item;
                _model.ChecklistItems = _model.ChecklistItems?.OrderBy(c => c.SortOrder).ToList() ?? new();
                _model.Comments ??= new();
                _startDate = _model.StartDate?.LocalDateTime;
                _dueDate = _model.DueDate?.LocalDateTime;
                CaptureBaseline();
                FloatService.ShowSnack("Task saved.", Severity.Success);
                FloatService.NotifyTaskItemsChanged();
            }
        }
    }

    private async Task DeleteAsync()
    {
        if (_model?.Id is null) return;
        var confirm = await DialogService.ShowMessageBoxAsync(new MessageBoxOptions
        {
            Title = "Delete task",
            Message = $"Delete '{_model.Title}'? This cannot be undone.",
            YesText = "Delete",
            CancelText = "Cancel"
        });
        if (confirm != true) return;

        var ok = await FloatService.ExecuteWithProgressAsync(
            () => Api.DeleteTaskItemAsync(_model.Id.Value), "Failed to delete task.");
        if (ok)
        {
            FloatService.ShowSnack("Task deleted.", Severity.Success);
            FloatService.NotifyTaskItemsChanged();
            _bypassDirtyCheck = true;
            Nav.NavigateTo("/tasks");
        }
    }

    private void CaptureBaseline()
    {
        _baseline = _model is null
            ? null
            : _model with { };
        _baselineStart = _startDate;
        _baselineDue = _dueDate;
        _childrenDirty = false;
    }

    private bool IsDirty()
    {
        if (_model is null || _baseline is null) return false;
        if (!string.IsNullOrWhiteSpace(_newChecklistTitle)) return true;
        if (!string.IsNullOrWhiteSpace(_newCommentBody)) return true;
        if (_childrenDirty) return true;
        return _model.Title != _baseline.Title
            || _model.Description != _baseline.Description
            || _model.Status != _baseline.Status
            || _model.Priority != _baseline.Priority
            || _model.CategoryId != _baseline.CategoryId
            || _model.EstimatedEffort != _baseline.EstimatedEffort
            || _model.ActualEffort != _baseline.ActualEffort
            || _startDate != _baselineStart
            || _dueDate != _baselineDue;
    }

    private async ValueTask OnLocationChangingAsync(LocationChangingContext context)
    {
        if (_bypassDirtyCheck || !IsDirty()) return;

        var confirm = await DialogService.ShowMessageBoxAsync(new MessageBoxOptions
        {
            Title = "Discard unsaved changes?",
            Message = "You have unsaved edits on this task. Leave the page and discard them?",
            YesText = "Discard",
            CancelText = "Stay"
        });

        if (confirm != true)
        {
            context.PreventNavigation();
        }
    }

    public void Dispose()
    {
        _locationChangingRegistration?.Dispose();
    }

    // Children are local-only — the server Updater syncs them from the parent
    // DTO on the next Save. Newly added items have no Id so the Updater treats
    // them as inserts; removals drop them from the list and the Updater hard-
    // deletes the matching rows via RelatedDeleteBehavior.RelationshipAndEntity.

    private void AddChecklist()
    {
        if (_model is null || string.IsNullOrWhiteSpace(_newChecklistTitle)) return;
        Checklist.Add(new ChecklistItemDto
        {
            Title = _newChecklistTitle!,
            TaskItemId = _model.Id ?? Guid.Empty,
            SortOrder = Checklist.Count
        });
        _newChecklistTitle = null;
        _childrenDirty = true;
    }

    private void ToggleChecklist(ChecklistItemDto item, bool completed)
    {
        var idx = Checklist.IndexOf(item);
        if (idx < 0) return;
        Checklist[idx] = item with { IsCompleted = completed };
        _childrenDirty = true;
    }

    private void DeleteChecklist(ChecklistItemDto item)
    {
        if (Checklist.Remove(item)) _childrenDirty = true;
    }

    private void AddComment()
    {
        if (_model is null || string.IsNullOrWhiteSpace(_newCommentBody)) return;
        Comments.Insert(0, new CommentDto
        {
            Body = _newCommentBody!,
            TaskItemId = _model.Id ?? Guid.Empty
        });
        _newCommentBody = null;
        _childrenDirty = true;
    }

    private void DeleteComment(CommentDto c)
    {
        if (Comments.Remove(c)) _childrenDirty = true;
    }
}
