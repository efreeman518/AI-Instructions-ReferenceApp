<Project Sdk="Uno.Sdk/6.6.0-dev.166">

  <!-- shortcut: this prerelease contains the upstream WASM RootElement startup-race fix;
       move to the first stable Uno.Sdk 6.6+ release when available. -->
  <PropertyGroup>
    <!-- Clear singular TargetFramework inherited from Directory.Build.props -->
    <TargetFramework />
    <!-- Keep fast default Wasm restores for local web work. Before Android/iOS
         package builds, restore once with BuildAllUnoTargets=true so platform
         Skia runtime packages are present in the NuGet asset graph. -->
    <TaskFlowUnoTargetFrameworks>net10.0-browserwasm;net10.0-android;net10.0-ios</TaskFlowUnoTargetFrameworks>
    <TargetFrameworks Condition="'$(TargetFrameworkOverride)'!=''">$(TargetFrameworkOverride)</TargetFrameworks>
    <TargetFrameworks Condition="'$(TargetFrameworkOverride)'=='' and '$(BuildAllUnoTargets)'=='true'">$(TaskFlowUnoTargetFrameworks)</TargetFrameworks>
    <TargetFrameworks Condition="'$(TargetFrameworkOverride)'=='' and '$(BuildAllUnoTargets)'!='true'">net10.0-browserwasm</TargetFrameworks>
    <OutputType>Exe</OutputType>
    <UnoSingleProject>true</UnoSingleProject>
    <ApplicationTitle>TaskFlow</ApplicationTitle>
    <ApplicationId>com.taskflow.uno</ApplicationId>
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
    <ApplicationVersion>1</ApplicationVersion>
    <IsAotCompatible>true</IsAotCompatible>

    <!-- Suppress Uno framework warnings that are not actionable in app code. -->
    <NoWarn>$(NoWarn);IL2026;IL3050;XA4214</NoWarn>

    <UnoFeatures>
      Material;
      Hosting;
      Toolkit;
      Logging;
      MVUX;
      Configuration;
      HttpKiota;
      Serialization;
      Localization;
      Navigation;
      Skia;
      SkiaRenderer;
      ThemeService;
    </UnoFeatures>

    <!-- Default to the real gateway. Enable mock mode explicitly with /p:UseMocks=true when needed. -->
    <UseMocks Condition="'$(UseMocks)'==''">false</UseMocks>

    <!-- Release artifacts must not carry interactive design/MCP tooling. -->
    <UnoDisableHotDesign Condition="'$(Configuration)'=='Release'">true</UnoDisableHotDesign>
    <UnoDisableMCPSupport Condition="'$(Configuration)'=='Release'">true</UnoDisableMCPSupport>

    <!-- shortcut: current stable Uno Navigation/Toolkit/WinUI packages emit upstream IL2104
         analysis failures under repository-wide TreatWarningsAsErrors. Re-enable trimming when
         those dependencies publish trim-clean annotations; keep Release publishing unblocked meanwhile. -->
    <PublishTrimmed Condition="'$(Configuration)'=='Release' AND '$(TargetFramework)'!='' AND $(TargetFramework.Contains('-browserwasm'))">false</PublishTrimmed>
  </PropertyGroup>

  <ItemGroup>
    <UnoSplashScreen Include="Assets\splashscreen.svg" BaseSize="128,128" Color="#6750A4" />
  </ItemGroup>

  <PropertyGroup Condition="'$(UseMocks)'=='true'">
    <DefineConstants>$(DefineConstants);USE_MOCKS</DefineConstants>
  </PropertyGroup>

  <PropertyGroup Condition="'$(TargetFramework)' != '' AND $(TargetFramework.Contains('-android'))">
    <!-- Appium/ADB sideloads only the APK, so Debug builds cannot rely on fast-deployed assemblies. -->
    <EmbedAssembliesIntoApk>true</EmbedAssembliesIntoApk>
    <AndroidEnableAssemblyCompression>false</AndroidEnableAssemblyCompression>
    <AndroidStoreUncompressedFileExtensions>.so;$(AndroidStoreUncompressedFileExtensions)</AndroidStoreUncompressedFileExtensions>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" />
    <PackageReference Include="Microsoft.Kiota.Abstractions" />
    <!-- Temporary direct reference lifting a vulnerable transitive - see Directory.Packages.props. -->
    <PackageReference Include="System.Security.Cryptography.Xml" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="System.Collections.Immutable" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\TaskFlow.Uno.Core\TaskFlow.Uno.Core.csproj" />
    <ProjectReference Include="..\TaskFlow.Uno.Presentation\TaskFlow.Uno.Presentation.csproj" />
  </ItemGroup>

  <!-- Workaround: Resizetizer sets WasmPWAManifestFile to a directory when
       no PWA manifest is configured. Clear it so ShellTask doesn't crash. -->
  <Target Name="_FixWasmPwaManifestPath"
          BeforeTargets="GenerateUnoWasmAssets"
          Condition="'$(WasmPWAManifestFile)' != '' AND !$(WasmPWAManifestFile.EndsWith('.json'))">
    <PropertyGroup>
      <WasmPWAManifestFile />
    </PropertyGroup>
  </Target>

  <!-- Workaround: WasmAppHost serves from the output root while Uno generates
       browser assets under $(TargetDir)wwwroot. Mirror those files into the
       output root so the hashed package and framework assets resolve at runtime. -->
  <Target Name="_MirrorWasmStaticAssetsForAppHost"
          AfterTargets="Build"
          Condition="'$(TargetPlatformIdentifier)' == 'BrowserWasm' AND Exists('$(TargetDir)wwwroot')">
    <ItemGroup>
      <_WasmStaticAssetsToMirror Include="$(TargetDir)wwwroot\**\*" />
    </ItemGroup>

    <Copy SourceFiles="@(_WasmStaticAssetsToMirror)"
          DestinationFiles="@(_WasmStaticAssetsToMirror->'$(TargetDir)%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

</Project>
