<Project Sdk="Uno.Sdk/6.5.31">
  <PropertyGroup>
    <!-- Clear singular TargetFramework inherited from Directory.Build.props -->
    <TargetFramework />
    <TargetFrameworks>net10.0-browserwasm</TargetFrameworks>
    <OutputType>Exe</OutputType>
    <UnoSingleProject>true</UnoSingleProject>
    <ApplicationTitle>TaskFlow</ApplicationTitle>
    <ApplicationId>com.taskflow.uno</ApplicationId>
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
    <ApplicationVersion>1</ApplicationVersion>
    <IsAotCompatible>true</IsAotCompatible>

    <!-- Suppress Uno Extensions trimming/AOT warnings (framework limitation, not app code) -->
    <NoWarn>$(NoWarn);IL2026;IL3050</NoWarn>

    <UnoFeatures>
      Material;
      Hosting;
      Toolkit;
      Logging;
      MVUX;
      Configuration;
      HttpKiota;
      Serialization;
      Localization;
      Navigation;
      ThemeService;
      Authentication;
    </UnoFeatures>

    <!-- Default to the real gateway. Enable mock mode explicitly with /p:UseMocks=true when needed. -->
    <UseMocks Condition="'$(UseMocks)'==''">false</UseMocks>
  </PropertyGroup>

  <ItemGroup>
    <UnoSplashScreen Include="Assets\splashscreen.svg" BaseSize="128,128" Color="#6750A4" />
  </ItemGroup>

  <PropertyGroup Condition="'$(UseMocks)'=='true'">
    <DefineConstants>$(DefineConstants);USE_MOCKS</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="System.Collections.Immutable" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\TaskFlow.Uno.Core\TaskFlow.Uno.Core.csproj" />
  </ItemGroup>

  <!-- Workaround: Resizetizer sets WasmPWAManifestFile to a directory when
       no PWA manifest is configured. Clear it so ShellTask doesn't crash. -->
  <Target Name="_FixWasmPwaManifestPath"
          BeforeTargets="GenerateUnoWasmAssets"
          Condition="'$(WasmPWAManifestFile)' != '' AND !$(WasmPWAManifestFile.EndsWith('.json'))">
    <PropertyGroup>
      <WasmPWAManifestFile />
    </PropertyGroup>
  </Target>

  <!-- Workaround: WasmAppHost serves from the output root while Uno generates
       browser assets under $(TargetDir)wwwroot. Mirror those files into the
       output root so the hashed package and framework assets resolve at runtime. -->
  <Target Name="_MirrorWasmStaticAssetsForAppHost"
          AfterTargets="Build"
          Condition="'$(TargetPlatformIdentifier)' == 'BrowserWasm' AND Exists('$(TargetDir)wwwroot')">
    <ItemGroup>
      <_WasmStaticAssetsToMirror Include="$(TargetDir)wwwroot\**\*" />
    </ItemGroup>

    <Copy SourceFiles="@(_WasmStaticAssetsToMirror)"
          DestinationFiles="@(_WasmStaticAssetsToMirror->'$(TargetDir)%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

</Project>
