<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:utu="using:Uno.Toolkit.UI"
    xmlns:conv="using:TaskFlow.Uno.Converters">

    <!-- ═══════════════════════════════════════════════════════
         Converters
         ═══════════════════════════════════════════════════════ -->
    <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    <conv:BoolToActiveTextConverter x:Key="BoolToActiveText" />
    <conv:NullableDateToShortDateConverter x:Key="NullableDateToShortDate" />

    <!-- ═══════════════════════════════════════════════════════
         Semantic accent brushes (use Material palette colors)
         ═══════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="AccentSuccessBrush" Color="#4CAF50" />
    <SolidColorBrush x:Key="AccentWarningBrush" Color="#FF9800" />
    <SolidColorBrush x:Key="AccentDangerBrush" Color="#F44336" />
    <SolidColorBrush x:Key="AccentInfoBrush" Color="#2196F3" />
    <SolidColorBrush x:Key="AccentSuccessLightBrush" Color="#C8E6C9" />
    <SolidColorBrush x:Key="AccentWarningLightBrush" Color="#FFE0B2" />
    <SolidColorBrush x:Key="AccentDangerLightBrush" Color="#FFCDD2" />
    <SolidColorBrush x:Key="AccentInfoLightBrush" Color="#BBDEFB" />
    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="#6750A4" />
    <SolidColorBrush x:Key="AccentPrimaryLightBrush" Color="#D0BCFF" />

    <!-- ═══════════════════════════════════════════════════════
         Spacing / Layout Constants
         ═══════════════════════════════════════════════════════ -->
    <Thickness x:Key="PagePadding">24,20,24,20</Thickness>
    <Thickness x:Key="PagePaddingNarrow">12,16,12,16</Thickness>
    <x:Double x:Key="ContentMaxWidth">1200</x:Double>
    <CornerRadius x:Key="CardRadius">12</CornerRadius>
    <CornerRadius x:Key="BadgeRadius">16</CornerRadius>
    <CornerRadius x:Key="ChipRadius">8</CornerRadius>

    <!-- ═══════════════════════════════════════════════════════
         Page Header
         ═══════════════════════════════════════════════════════ -->
    <Style x:Key="PageHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource TitleLargeTextBlockStyle}">
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <Style x:Key="PageSubheaderStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
        <Setter Property="Opacity" Value="0.6" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource TitleTextBlockStyle}">
        <Setter Property="Margin" Value="0,8,0,8" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════
         Stat Card — Dashboard summary cards
         ═══════════════════════════════════════════════════════ -->
    <Style x:Key="StatCardStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource CardRadius}" />
        <Setter Property="Padding" Value="20,16" />
        <Setter Property="Background" Value="{ThemeResource SurfaceVariantBrush}" />
        <Setter Property="MinHeight" Value="100" />
    </Style>

    <Style x:Key="StatValueStyle" TargetType="TextBlock" BasedOn="{StaticResource TitleLargeTextBlockStyle}">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style x:Key="StatLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
        <Setter Property="Opacity" Value="0.7" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="50" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════
         Status Badge
         ═══════════════════════════════════════════════════════ -->
    <Style x:Key="BadgeStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource BadgeRadius}" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Background" Value="{ThemeResource SystemControlBackgroundBaseLowBrush}" />
    </Style>

    <Style x:Key="BadgeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="CharacterSpacing" Value="30" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════
         List Item Card (for task rows, tag rows, etc.)
         ═══════════════════════════════════════════════════════ -->
    <Style x:Key="ListItemCardStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource ChipRadius}" />
        <Setter Property="Padding" Value="18,14" />
        <Setter Property="Background" Value="{ThemeResource SurfaceVariantBrush}" />
        <Setter Property="Margin" Value="0,2" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════
         Inline Form Card
         ═══════════════════════════════════════════════════════ -->
    <Style x:Key="InlineFormCardStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource CardRadius}" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="Background" Value="{ThemeResource SurfaceVariantBrush}" />
    </Style>

    <Style x:Key="FormActionButtonStyle" TargetType="Button" BasedOn="{StaticResource FilledButtonStyle}">
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="MinWidth" Value="116" />
        <Setter Property="Padding" Value="18,12" />
        <Setter Property="CornerRadius" Value="20" />
    </Style>

    <Style x:Key="PanelNavButtonStyle" TargetType="Button" BasedOn="{StaticResource TextButtonStyle}">
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="CornerRadius" Value="18" />
    </Style>

    <Style x:Key="PagerNumberButtonStyle" TargetType="Button" BasedOn="{StaticResource PanelNavButtonStyle}">
        <Setter Property="MinWidth" Value="44" />
        <Setter Property="Padding" Value="12,10" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════
         Empty State
         ═══════════════════════════════════════════════════════ -->
    <Style x:Key="EmptyStateTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Opacity" Value="0.5" />
        <Setter Property="Margin" Value="0,40" />
        <Setter Property="FontStyle" Value="Italic" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════
         FAB (Floating Action Button) style
         ═══════════════════════════════════════════════════════ -->
    <Style x:Key="FabButtonStyle" TargetType="Button" BasedOn="{StaticResource FilledButtonStyle}">
        <Setter Property="Height" Value="56" />
        <Setter Property="MinWidth" Value="56" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════
         Delete / Danger Button
         ═══════════════════════════════════════════════════════ -->
    <Style x:Key="DangerButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource AccentDangerBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentDangerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,6" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════
         Form TextBox — visible border for all input fields
         ═══════════════════════════════════════════════════════ -->
    <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
        <Setter Property="BorderBrush" Value="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,10" />
    </Style>

</ResourceDictionary>
