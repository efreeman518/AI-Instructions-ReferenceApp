<Page x:Class="TaskFlow.Uno.Views.TaskDetailPage"
      x:Name="TaskDetailRoot"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <ScrollViewer>
        <utu:AutoLayout Spacing="16"
                        Padding="{utu:Responsive Normal='16,12,16,16', Wide='24,16,24,24'}"
                        MaxWidth="{StaticResource ContentMaxWidth}">

            <!-- Back link -->
            <Button uen:Navigation.Request="TaskList"
                    Style="{StaticResource TextButtonStyle}"
                    Padding="0,4">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72B;" FontSize="12" />
                    <TextBlock Text="Back to Tasks" Style="{StaticResource LabelMedium}" />
                </StackPanel>
            </Button>

            <!-- Header -->
            <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <utu:AutoLayout Spacing="8">
                        <TextBlock Text="{Binding Task.Title}" Style="{StaticResource TitleLarge}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Style="{StaticResource BadgeStyle}" Background="{StaticResource AccentInfoBrush}">
                                <TextBlock Text="{Binding Task.Status}" Style="{StaticResource BadgeTextStyle}" Foreground="White" />
                            </Border>
                            <Border Style="{StaticResource BadgeStyle}">
                                <TextBlock Text="{Binding Task.Priority}" Style="{StaticResource BadgeTextStyle}" />
                            </Border>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE8B7;" FontSize="12" Opacity="0.5" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Task.CategoryName}" Opacity="0.5" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </utu:AutoLayout>
                    <StackPanel Grid.Column="1"
                                Orientation="{utu:Responsive Normal=Vertical, Wide=Horizontal}"
                                Spacing="8" VerticalAlignment="Top">
                        <Button Content="&#xE70F;  Edit" Command="{Binding EditTask}" Style="{StaticResource FilledButtonStyle}" Padding="16,8" />
                        <Button Content="Delete" Command="{Binding DeleteTask}" Style="{StaticResource DangerButtonStyle}" />
                    </StackPanel>
                </Grid>

                <!-- Description -->
                <utu:CardContentControl Style="{StaticResource FilledCardContentControlStyle}"
                                        Visibility="{Binding Task.Description, Converter={x:Null}}">
                    <utu:AutoLayout Spacing="4">
                        <TextBlock Text="Description" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Task.Description}" TextWrapping="Wrap" />
                    </utu:AutoLayout>
                </utu:CardContentControl>

                <!-- Dates -->
                <utu:CardContentControl Style="{StaticResource FilledCardContentControlStyle}">
                    <StackPanel Orientation="{utu:Responsive Normal=Vertical, Wide=Horizontal}" Spacing="32">
                        <utu:AutoLayout Spacing="2">
                            <TextBlock Text="START DATE" Style="{StaticResource StatLabelStyle}" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE787;" FontSize="14" Opacity="0.6" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Task.StartDate}" Style="{StaticResource BodyTextBlockStyle}" />
                            </StackPanel>
                        </utu:AutoLayout>
                        <utu:AutoLayout Spacing="2">
                            <TextBlock Text="DUE DATE" Style="{StaticResource StatLabelStyle}" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE783;" FontSize="14" Opacity="0.6" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Task.DueDate}" Style="{StaticResource BodyTextBlockStyle}" />
                            </StackPanel>
                        </utu:AutoLayout>
                    </StackPanel>
                </utu:CardContentControl>

                <!-- Checklist Section -->
                <utu:CardContentControl Style="{StaticResource FilledCardContentControlStyle}">
                    <utu:AutoLayout Spacing="8">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE73A;" FontSize="18" Foreground="{StaticResource AccentSuccessBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Checklist" Style="{StaticResource TitleSmall}" />
                        </Grid>

                        <ListView ItemsSource="{Binding ChecklistItems}" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="8" Padding="4,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsCompleted}"
                                                  Command="{Binding DataContext.ToggleChecklistItem, ElementName=TaskDetailRoot}"
                                                  CommandParameter="{Binding}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Title}" VerticalAlignment="Center" />
                                        <Button Grid.Column="2" Content="&#xE74D;"
                                                FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14"
                                                Command="{Binding DataContext.DeleteChecklistItem, ElementName=TaskDetailRoot}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" Padding="6" Opacity="0.5" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox PlaceholderText="Add checklist item..." Text="{Binding NewChecklistTitle, Mode=TwoWay}" />
                            <Button Grid.Column="1" Content="Add" Command="{Binding AddChecklistItem}" Style="{StaticResource FilledButtonStyle}" Padding="16,6" />
                        </Grid>
                    </utu:AutoLayout>
                </utu:CardContentControl>

                <!-- Comments Section -->
                <utu:CardContentControl Style="{StaticResource FilledCardContentControlStyle}">
                    <utu:AutoLayout Spacing="8">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE8F2;" FontSize="18" Foreground="{StaticResource AccentInfoBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Comments" Style="{StaticResource TitleSmall}" />
                        </Grid>

                        <ListView ItemsSource="{Binding Comments}" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ListItemCardStyle}" Background="{ThemeResource SystemControlBackgroundBaseLowBrush}">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Glyph="&#xE77B;" FontSize="16" Opacity="0.4" VerticalAlignment="Top" Margin="0,2,0,0" />
                                            <TextBlock Grid.Column="1" Text="{Binding Body}" TextWrapping="Wrap" />
                                            <Button Grid.Column="2" Content="&#xE74D;"
                                                    FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14"
                                                    Command="{Binding DataContext.DeleteComment, ElementName=TaskDetailRoot}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" Padding="6" Opacity="0.5" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox PlaceholderText="Write a comment..." Text="{Binding NewCommentBody, Mode=TwoWay}"
                                     AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" />
                            <Button Grid.Column="1" Content="Post" Command="{Binding AddComment}" Style="{StaticResource FilledButtonStyle}" Padding="16,6" VerticalAlignment="Bottom" />
                        </Grid>
                    </utu:AutoLayout>
                </utu:CardContentControl>

                <!-- Attachments Section -->
                <utu:CardContentControl Style="{StaticResource FilledCardContentControlStyle}">
                    <utu:AutoLayout Spacing="8">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE723;" FontSize="18" Foreground="{StaticResource AccentWarningBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Attachments" Style="{StaticResource TitleSmall}" />
                        </Grid>

                        <ListView ItemsSource="{Binding Attachments}" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="8,4" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xE7C3;" FontSize="14" Opacity="0.5" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding FileName}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding ContentType}" Opacity="0.4"
                                                   VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" />
                                        <Button Grid.Column="3" Content="&#xE74D;"
                                                FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14"
                                                Command="{Binding DataContext.DeleteAttachment, ElementName=TaskDetailRoot}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" Padding="6" Opacity="0.5" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </utu:AutoLayout>
                </utu:CardContentControl>

                <!-- Sub-Tasks Section -->
                <utu:CardContentControl Style="{StaticResource FilledCardContentControlStyle}">
                    <utu:AutoLayout Spacing="8">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE81E;" FontSize="18" Foreground="{StaticResource AccentPrimaryLightBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Sub-Tasks" Style="{StaticResource TitleSmall}" />
                        </Grid>

                        <ListView ItemsSource="{Binding SubTasks}" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ListItemCardStyle}">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center"
                                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <Border Grid.Column="1" Style="{StaticResource BadgeStyle}">
                                                <TextBlock Text="{Binding Status}" Style="{StaticResource BadgeTextStyle}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </utu:AutoLayout>
                </utu:CardContentControl>
            </utu:AutoLayout>
    </ScrollViewer>
</Page>
