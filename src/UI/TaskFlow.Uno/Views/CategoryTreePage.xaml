<Page x:Class="TaskFlow.Uno.Views.CategoryTreePage"
    x:Name="CategoryTreeRoot"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uer="using:Uno.Extensions.Reactive.UI"
      Background="{ThemeResource BackgroundBrush}">

    <Grid Padding="{utu:Responsive Normal='16,16,16,16', Wide='24,24,24,24'}" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <utu:AutoLayout Grid.Row="0" Spacing="2">
            <TextBlock Text="Categories" Style="{StaticResource TitleLarge}" />
            <TextBlock Text="Organize tasks with hierarchical categories"
                       Style="{StaticResource BodyMedium}"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
        </utu:AutoLayout>

        <!-- Create/Edit Form -->
        <Border Grid.Row="1" Style="{StaticResource InlineFormCardStyle}">
            <utu:AutoLayout Spacing="8">
                <TextBlock Text="ADD CATEGORY" Style="{StaticResource StatLabelStyle}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" PlaceholderText="Category name"
                             Text="{Binding NewCategoryName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="48" />
                    <TextBox Grid.Column="1" PlaceholderText="Description (optional)"
                             Text="{Binding NewCategoryDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Visibility="{utu:Responsive Normal=Collapsed, Wide=Visible}"
                             MinHeight="48" />
                    <Button Grid.Column="2"
                            Command="{Binding SaveCategory}"
                            Style="{StaticResource FormActionButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" />
                            <TextBlock Text="Save" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="3"
                            Command="{Binding CancelEdit}"
                            Style="{StaticResource PanelNavButtonStyle}"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Cancel" />
                    </Button>
                </Grid>
                <TextBox PlaceholderText="Description (optional)"
                         Text="{Binding NewCategoryDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Visibility="{utu:Responsive Normal=Visible, Wide=Collapsed}"
                         MinHeight="48" />
            </utu:AutoLayout>
        </Border>

        <!-- Category List -->
        <uer:FeedView Grid.Row="2" Source="{Binding Categories}">
            <uer:FeedView.ValueTemplate>
                <DataTemplate>
                    <ListView ItemsSource="{Binding Data}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ListItemCardStyle}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <FontIcon Glyph="&#xE8B7;"
                                                  FontSize="16"
                                                  Foreground="{StaticResource AccentPrimaryLightBrush}"
                                                  VerticalAlignment="Center" />

                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <TextBlock Text="{Binding Description}"
                                                       Opacity="0.6"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <Border Grid.Column="2" Style="{StaticResource BadgeStyle}">
                                            <TextBlock Text="{Binding IsActive, Converter={StaticResource BoolToActiveText}}" Style="{StaticResource BadgeTextStyle}" />
                                        </Border>

                                        <Button Grid.Column="3"
                                                Content="&#xE70F;"
                                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                FontSize="14"
                                                Command="{Binding DataContext.StartEdit, ElementName=CategoryTreeRoot}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent"
                                                Padding="8"
                                                Opacity="0.7" />

                                        <Button Grid.Column="4"
                                                Content="&#xE74D;"
                                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                FontSize="14"
                                                Command="{Binding DataContext.DeleteCategory, ElementName=CategoryTreeRoot}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent"
                                                Padding="8"
                                                Foreground="{StaticResource AccentDangerBrush}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DataTemplate>
            </uer:FeedView.ValueTemplate>
            <uer:FeedView.ProgressTemplate>
                <DataTemplate>
                    <ProgressRing IsActive="True"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Width="48" Height="48" />
                </DataTemplate>
            </uer:FeedView.ProgressTemplate>
            <uer:FeedView.NoneTemplate>
                <DataTemplate>
                    <TextBlock Text="No categories yet. Add one above!"
                               Style="{StaticResource EmptyStateTextStyle}" />
                </DataTemplate>
            </uer:FeedView.NoneTemplate>
        </uer:FeedView>
    </Grid>
</Page>
