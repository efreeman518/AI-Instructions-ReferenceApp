<Page x:Class="TaskFlow.Uno.Views.TagManagementPage"
      x:Name="TagManagementRoot"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uer="using:Uno.Extensions.Reactive.UI"
      Background="{ThemeResource BackgroundBrush}">

    <Grid Padding="{utu:Responsive Normal='16,16,16,16', Wide='24,24,24,24'}" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <utu:AutoLayout Grid.Row="0" Spacing="2">
            <TextBlock Text="Tags" Style="{StaticResource TitleLarge}" />
            <TextBlock Text="Label and color-code your tasks"
                       Style="{StaticResource BodyMedium}"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
        </utu:AutoLayout>

        <!-- Create Form -->
        <Border Grid.Row="1" Style="{StaticResource InlineFormCardStyle}">
            <utu:AutoLayout Spacing="8">
                <TextBlock Text="ADD TAG" Style="{StaticResource StatLabelStyle}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" PlaceholderText="Tag name"
                             Text="{Binding NewTagName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MinHeight="48" />
                    <TextBox Grid.Column="1" PlaceholderText="#hex color"
                             Text="{Binding NewTagColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MinHeight="48" />
                    <Button Grid.Column="2"
                            Command="{Binding CreateTag}"
                            Style="{StaticResource FormActionButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" />
                            <TextBlock Text="Add" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </utu:AutoLayout>
        </Border>

        <!-- Tag List -->
        <uer:FeedView Grid.Row="2" Source="{Binding Tags}">
            <uer:FeedView.ValueTemplate>
                <DataTemplate>
                    <ListView ItemsSource="{Binding Data}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ListItemCardStyle}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12"
                                                Background="{Binding Color}" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xE8EC;" FontSize="12" Foreground="White"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>

                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />

                                        <Button Grid.Column="2" Content="&#xE70F;"
                                                FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14"
                                                Command="{Binding DataContext.StartEdit, ElementName=TagManagementRoot}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" Padding="8" Opacity="0.6" />

                                        <Button Grid.Column="3" Content="&#xE74D;"
                                                FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14"
                                                Command="{Binding DataContext.DeleteTag, ElementName=TagManagementRoot}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" Padding="8" Foreground="{StaticResource AccentDangerBrush}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DataTemplate>
            </uer:FeedView.ValueTemplate>
            <uer:FeedView.ProgressTemplate>
                <DataTemplate>
                    <ProgressRing IsActive="True"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Width="48" Height="48" />
                </DataTemplate>
            </uer:FeedView.ProgressTemplate>
            <uer:FeedView.NoneTemplate>
                <DataTemplate>
                    <TextBlock Text="No tags yet. Add one above!"
                               Style="{StaticResource EmptyStateTextStyle}" />
                </DataTemplate>
            </uer:FeedView.NoneTemplate>
        </uer:FeedView>
    </Grid>
</Page>
