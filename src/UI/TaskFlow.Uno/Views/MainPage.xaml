<Page x:Class="TaskFlow.Uno.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:ut="using:Uno.Themes"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:controls="using:TaskFlow.Uno.Views.Controls"
      Background="{ThemeResource BackgroundBrush}"
      utu:StatusBar.Background="{ThemeResource PrimaryBrush}"
      utu:StatusBar.Foreground="AutoInverse">

    <Page.Resources>
        <x:Double x:Key="NavigationTabBarItemIconHeight">22</x:Double>
        <Style x:Key="HeaderActionButtonStyle" TargetType="Button" BasedOn="{StaticResource TextButtonStyle}">
            <Setter Property="Foreground" Value="{ThemeResource OnPrimaryBrush}" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid uen:Region.Attached="True"
              utu:SafeArea.Insets="VisibleBounds">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Row="0"
                  Grid.ColumnSpan="2"
                  Background="{ThemeResource PrimaryBrush}"
                  Padding="{utu:Responsive Normal='12,8', Wide='16,10'}"
                  ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE9D5;" FontSize="22" Foreground="{ThemeResource OnPrimaryBrush}" />
                    <TextBlock Text="TaskFlow"
                               Style="{StaticResource TitleMedium}"
                               Foreground="{ThemeResource OnPrimaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Button Grid.Column="2"
                        Content="New Task"
                        Style="{StaticResource HeaderActionButtonStyle}"
                        uen:Navigation.Request="TaskItem"
                        AutomationProperties.Name="Create new task"
                        ToolTipService.ToolTip="New Task"
                        Visibility="{utu:Responsive Normal=Collapsed, Wide=Visible}">
                    <ut:ControlExtensions.Icon>
                        <FontIcon Glyph="&#xE710;" />
                    </ut:ControlExtensions.Icon>
                </Button>

                <Button Grid.Column="3"
                        Style="{StaticResource HeaderActionButtonStyle}"
                        uen:Navigation.Request="Settings"
                        AutomationProperties.Name="Settings"
                        ToolTipService.ToolTip="Settings">
                    <ut:ControlExtensions.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </ut:ControlExtensions.Icon>
                </Button>
            </Grid>

            <utu:AutoLayout Grid.Row="1"
                            Grid.RowSpan="2"
                            Grid.Column="0"
                            Background="{ThemeResource SurfaceBrush}"
                            BorderBrush="{ThemeResource OutlineVariantBrush}"
                            BorderThickness="0,0,1,0"
                            Visibility="{utu:Responsive Normal=Collapsed, Wide=Visible}"
                            Width="168">
                <utu:TabBar uen:Region.Attached="True"
                            Style="{StaticResource VerticalTabBarStyle}"
                            utu:AutoLayout.PrimaryAlignment="Stretch">
                    <utu:TabBarItem uen:Region.Name="Dashboard" Content="Dashboard">
                        <utu:TabBarItem.Icon>
                            <FontIcon Glyph="&#xE80F;" />
                        </utu:TabBarItem.Icon>
                    </utu:TabBarItem>
                    <utu:TabBarItem uen:Region.Name="TaskList" Content="Tasks">
                        <utu:TabBarItem.Icon>
                            <FontIcon Glyph="&#xE9D5;" />
                        </utu:TabBarItem.Icon>
                    </utu:TabBarItem>
                    <utu:TabBarItem uen:Region.Name="Categories" Content="Categories">
                        <utu:TabBarItem.Icon>
                            <FontIcon Glyph="&#xE8B7;" />
                        </utu:TabBarItem.Icon>
                    </utu:TabBarItem>
                    <utu:TabBarItem uen:Region.Name="Tags" Content="Tags">
                        <utu:TabBarItem.Icon>
                            <FontIcon Glyph="&#xE8EC;" />
                        </utu:TabBarItem.Icon>
                    </utu:TabBarItem>
                </utu:TabBar>

                <Button Content="Add Task"
                        Style="{StaticResource FormActionButtonStyle}"
                        Margin="12,8,12,16"
                        HorizontalAlignment="Stretch"
                        uen:Navigation.Request="TaskItem"
                        AutomationProperties.Name="Create new task">
                    <ut:ControlExtensions.Icon>
                        <FontIcon Glyph="&#xE710;" />
                    </ut:ControlExtensions.Icon>
                </Button>
            </utu:AutoLayout>

            <Grid Grid.Row="1"
                  Grid.Column="1"
                  x:Name="RootGrid"
                  uen:Region.Attached="True"
                  uen:Region.Navigator="Visibility" />

            <utu:TabBar Grid.Row="2"
                        Grid.Column="1"
                        Visibility="{utu:Responsive Normal=Visible, Wide=Collapsed}"
                        uen:Region.Attached="True"
                        Style="{StaticResource BottomTabBarStyle}">
                <utu:TabBarItem uen:Region.Name="Dashboard" Content="Home"
                                AutomationProperties.AutomationId="NavDashboard">
                    <utu:TabBarItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </utu:TabBarItem.Icon>
                </utu:TabBarItem>
                <utu:TabBarItem uen:Region.Name="TaskList" Content="Tasks"
                                AutomationProperties.AutomationId="NavTasks">
                    <utu:TabBarItem.Icon>
                        <FontIcon Glyph="&#xE9D5;" />
                    </utu:TabBarItem.Icon>
                </utu:TabBarItem>
                <utu:TabBarItem uen:Region.Name="Categories" Content="Categories">
                    <utu:TabBarItem.Icon>
                        <FontIcon Glyph="&#xE8B7;" />
                    </utu:TabBarItem.Icon>
                </utu:TabBarItem>
                <utu:TabBarItem uen:Region.Name="Tags" Content="Tags">
                    <utu:TabBarItem.Icon>
                        <FontIcon Glyph="&#xE8EC;" />
                    </utu:TabBarItem.Icon>
                </utu:TabBarItem>
            </utu:TabBar>
        </Grid>

        <ProgressBar IsIndeterminate="True"
                     VerticalAlignment="Top"
                     HorizontalAlignment="Stretch"
                     Height="2"
                     Visibility="{Binding Busy.IsActive, Converter={StaticResource BoolToVisibility}}" />

        <Button Style="{StaticResource FabButtonStyle}"
                uen:Navigation.Request="TaskItem"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Margin="16,0,16,82"
                Visibility="{utu:Responsive Normal=Visible, Wide=Collapsed}"
                AutomationProperties.Name="Create new task"
                AutomationProperties.AutomationId="NewTaskButton"
                ToolTipService.ToolTip="New Task">
            <ut:ControlExtensions.Icon>
                <FontIcon Glyph="&#xE710;" />
            </ut:ControlExtensions.Icon>
        </Button>

        <controls:NotificationHost Items="{Binding Notifications.Items}"
                                   VerticalAlignment="Top"
                                   HorizontalAlignment="Right"
                                   MaxWidth="420"
                                   Margin="16"
                                   Visibility="{utu:Responsive Normal=Collapsed, Wide=Visible}" />
        <controls:NotificationHost Items="{Binding Notifications.Items}"
                                   VerticalAlignment="Bottom"
                                   HorizontalAlignment="Stretch"
                                   Margin="8,0,8,72"
                                   Visibility="{utu:Responsive Normal=Visible, Wide=Collapsed}" />
    </Grid>
</Page>
