<Page x:Class="TaskFlow.Uno.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <ScrollViewer>
        <utu:AutoLayout Padding="{utu:Responsive Normal='16,16,16,16', Wide='32,24,32,24'}"
                        Spacing="20"
                        MaxWidth="1200"
                        utu:AutoLayout.PrimaryAlignment="Stretch">

            <!-- Page Header -->
            <utu:AutoLayout Spacing="4" Padding="0,4,0,0">
                <TextBlock Text="Dashboard" Style="{StaticResource TitleLarge}" />
                <TextBlock Text="Overview of your tasks and activity"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                           Style="{StaticResource BodyMedium}" />
            </utu:AutoLayout>

            <!-- Stats Grid - uniform 3 columns -->
            <Grid ColumnSpacing="12" RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Column="0" Grid.Row="0"
                        Background="{ThemeResource SurfaceVariantBrush}"
                        CornerRadius="16" Padding="16" MinHeight="110">
                    <utu:AutoLayout Spacing="6">
                        <utu:AutoLayout Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE9D5;" FontSize="20" Foreground="{ThemeResource PrimaryBrush}" utu:AutoLayout.CounterAlignment="Center" />
                            <TextBlock Text="Total" Style="{StaticResource LabelLarge}" Foreground="{ThemeResource OnSurfaceVariantBrush}" utu:AutoLayout.CounterAlignment="Center" />
                        </utu:AutoLayout>
                        <TextBlock Text="{Binding Summary.TotalTasks}" Style="{StaticResource DisplaySmall}" />
                    </utu:AutoLayout>
                </Border>

                <Border Grid.Column="1" Grid.Row="0"
                        Background="{ThemeResource SurfaceVariantBrush}"
                        CornerRadius="16" Padding="16" MinHeight="110">
                    <utu:AutoLayout Spacing="6">
                        <utu:AutoLayout Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8B7;" FontSize="20" Foreground="{StaticResource AccentInfoBrush}" utu:AutoLayout.CounterAlignment="Center" />
                            <TextBlock Text="Open" Style="{StaticResource LabelLarge}" Foreground="{ThemeResource OnSurfaceVariantBrush}" utu:AutoLayout.CounterAlignment="Center" />
                        </utu:AutoLayout>
                        <TextBlock Text="{Binding Summary.OpenTasks}" Style="{StaticResource DisplaySmall}" />
                    </utu:AutoLayout>
                </Border>

                <Border Grid.Column="2" Grid.Row="0"
                        Background="{ThemeResource SurfaceVariantBrush}"
                        CornerRadius="16" Padding="16" MinHeight="110">
                    <utu:AutoLayout Spacing="6">
                        <utu:AutoLayout Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xEA62;" FontSize="20" Foreground="{StaticResource AccentWarningBrush}" utu:AutoLayout.CounterAlignment="Center" />
                            <TextBlock Text="In Progress" Style="{StaticResource LabelLarge}" Foreground="{ThemeResource OnSurfaceVariantBrush}" utu:AutoLayout.CounterAlignment="Center" />
                        </utu:AutoLayout>
                        <TextBlock Text="{Binding Summary.InProgressTasks}" Style="{StaticResource DisplaySmall}" />
                    </utu:AutoLayout>
                </Border>

                <Border Grid.Column="0" Grid.Row="1"
                        Background="{ThemeResource SurfaceVariantBrush}"
                        CornerRadius="16" Padding="16" MinHeight="110">
                    <utu:AutoLayout Spacing="6">
                        <utu:AutoLayout Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE73E;" FontSize="20" Foreground="{StaticResource AccentSuccessBrush}" utu:AutoLayout.CounterAlignment="Center" />
                            <TextBlock Text="Completed" Style="{StaticResource LabelLarge}" Foreground="{ThemeResource OnSurfaceVariantBrush}" utu:AutoLayout.CounterAlignment="Center" />
                        </utu:AutoLayout>
                        <TextBlock Text="{Binding Summary.CompletedTasks}" Style="{StaticResource DisplaySmall}" />
                    </utu:AutoLayout>
                </Border>

                <Border Grid.Column="1" Grid.Row="1"
                        Background="{ThemeResource SurfaceVariantBrush}"
                        CornerRadius="16" Padding="16" MinHeight="110">
                    <utu:AutoLayout Spacing="6">
                        <utu:AutoLayout Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE7BA;" FontSize="20" Foreground="{StaticResource AccentWarningBrush}" utu:AutoLayout.CounterAlignment="Center" />
                            <TextBlock Text="Blocked" Style="{StaticResource LabelLarge}" Foreground="{ThemeResource OnSurfaceVariantBrush}" utu:AutoLayout.CounterAlignment="Center" />
                        </utu:AutoLayout>
                        <TextBlock Text="{Binding Summary.BlockedTasks}" Style="{StaticResource DisplaySmall}" Foreground="{StaticResource AccentWarningBrush}" />
                    </utu:AutoLayout>
                </Border>

                <Border Grid.Column="2" Grid.Row="1"
                        Background="{ThemeResource SurfaceVariantBrush}"
                        CornerRadius="16" Padding="16" MinHeight="110">
                    <utu:AutoLayout Spacing="6">
                        <utu:AutoLayout Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE783;" FontSize="20" Foreground="{StaticResource AccentDangerBrush}" utu:AutoLayout.CounterAlignment="Center" />
                            <TextBlock Text="Overdue" Style="{StaticResource LabelLarge}" Foreground="{ThemeResource OnSurfaceVariantBrush}" utu:AutoLayout.CounterAlignment="Center" />
                        </utu:AutoLayout>
                        <TextBlock Text="{Binding Summary.OverdueTasks}" Style="{StaticResource DisplaySmall}" Foreground="{StaticResource AccentDangerBrush}" />
                    </utu:AutoLayout>
                </Border>
            </Grid>

            <!-- Quick Actions -->
            <utu:AutoLayout Orientation="Horizontal" Spacing="12" Padding="0,4,0,0">
                <Button uen:Navigation.Request="TaskForm"
                        Style="{StaticResource FilledButtonStyle}"
                        CornerRadius="20" Padding="20,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                        <TextBlock Text="New Task" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button uen:Navigation.Request="TaskList"
                        Style="{StaticResource TextButtonStyle}"
                        Foreground="{ThemeResource PrimaryBrush}"
                        CornerRadius="20" Padding="16,10">
                    <TextBlock Text="View All Tasks" />
                </Button>
                <Button uen:Navigation.Request="Categories"
                        Style="{StaticResource TextButtonStyle}"
                        Foreground="{ThemeResource PrimaryBrush}"
                        CornerRadius="20" Padding="16,10">
                    <TextBlock Text="Manage Categories" />
                </Button>
                <Button uen:Navigation.Request="Tags"
                        Style="{StaticResource TextButtonStyle}"
                        Foreground="{ThemeResource PrimaryBrush}"
                        CornerRadius="20" Padding="16,10">
                    <TextBlock Text="Manage Tags" />
                </Button>
            </utu:AutoLayout>

            <!-- Recent Activity -->
            <utu:AutoLayout Spacing="8">
                <TextBlock Text="Recent Activity"
                           Style="{StaticResource TitleMedium}"
                           Padding="0,4,0,4" />

                <ListView ItemsSource="{Binding Summary.RecentActivity}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{ThemeResource SurfaceVariantBrush}"
                                    CornerRadius="12" Padding="14,10"
                                    Margin="0,3">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="&#xE9D5;" FontSize="14"
                                              Foreground="{ThemeResource PrimaryBrush}"
                                              VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Title}"
                                               Style="{StaticResource BodyMedium}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                    <Border Grid.Column="2" Padding="8,3" CornerRadius="10"
                                            Background="{ThemeResource SurfaceBrush}"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Status}" Style="{StaticResource LabelSmall}" />
                                    </Border>
                                    <Border Grid.Column="3" Padding="8,3" CornerRadius="10"
                                            Background="{ThemeResource SurfaceBrush}"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Priority}" Style="{StaticResource LabelSmall}" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </utu:AutoLayout>

        </utu:AutoLayout>
    </ScrollViewer>
</Page>