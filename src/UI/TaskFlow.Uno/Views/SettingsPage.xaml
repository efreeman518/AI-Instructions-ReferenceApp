<Page x:Class="TaskFlow.Uno.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <ScrollViewer>
        <utu:AutoLayout Padding="{utu:Responsive Normal='16,16,16,16', Wide='32,24,32,24'}"
                        Spacing="20"
                        MaxWidth="1200"
                        utu:AutoLayout.PrimaryAlignment="Stretch">

            <!-- Page Header -->
            <utu:AutoLayout Spacing="4" Padding="0,4,0,0">
                <TextBlock Text="Settings" Style="{StaticResource TitleLarge}" />
                <TextBlock Text="Configure application preferences"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                           Style="{StaticResource BodyMedium}" />
            </utu:AutoLayout>

            <!-- API Configuration -->
            <Border Background="{ThemeResource SurfaceVariantBrush}"
                    CornerRadius="16"
                    Padding="20">
                <utu:AutoLayout Spacing="16">
                    <utu:AutoLayout Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE774;" FontSize="20"
                                  Foreground="{ThemeResource PrimaryBrush}"
                                  utu:AutoLayout.CounterAlignment="Center" />
                        <TextBlock Text="API Configuration"
                                   Style="{StaticResource TitleMedium}"
                                   Foreground="{ThemeResource OnSurfaceBrush}"
                                   utu:AutoLayout.CounterAlignment="Center" />
                    </utu:AutoLayout>

                    <TextBox Header="Gateway URL"
                             Text="{Binding GatewayUrl, Mode=TwoWay}"
                             PlaceholderText="https://localhost:7120" />

                    <ToggleSwitch Header="Use Mock Data"
                                  IsOn="{Binding UseMocks, Mode=TwoWay}"
                                  OnContent="Using mock data"
                                  OffContent="Using live API" />
                </utu:AutoLayout>
            </Border>

            <!-- About -->
            <Border Background="{ThemeResource SurfaceVariantBrush}"
                    CornerRadius="16"
                    Padding="20">
                <utu:AutoLayout Spacing="12">
                    <utu:AutoLayout Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE946;" FontSize="20"
                                  Foreground="{StaticResource AccentInfoBrush}"
                                  utu:AutoLayout.CounterAlignment="Center" />
                        <TextBlock Text="About"
                                   Style="{StaticResource TitleMedium}"
                                   Foreground="{ThemeResource OnSurfaceBrush}"
                                   utu:AutoLayout.CounterAlignment="Center" />
                    </utu:AutoLayout>

                    <utu:AutoLayout Spacing="4">
                        <TextBlock Text="TaskFlow"
                                   Style="{StaticResource TitleSmall}"
                                   Foreground="{ThemeResource OnSurfaceBrush}" />
                        <TextBlock Text="Version 1.0"
                                   Style="{StaticResource BodySmall}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                        <TextBlock Text="Built with Uno Platform + .NET 10"
                                   Style="{StaticResource LabelSmall}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                    </utu:AutoLayout>
                </utu:AutoLayout>
            </Border>

        </utu:AutoLayout>
    </ScrollViewer>
</Page>
