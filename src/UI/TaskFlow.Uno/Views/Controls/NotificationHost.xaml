<UserControl x:Class="TaskFlow.Uno.Views.Controls.NotificationHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
             xmlns:conv="using:TaskFlow.Uno.Converters">
    <UserControl.Resources>
        <conv:SeverityToInfoBarSeverityConverter x:Key="SeverityToInfoBar" />
    </UserControl.Resources>

    <ItemsControl ItemsSource="{x:Bind Items, Mode=OneWay}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Orientation="Vertical" Spacing="8" />
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <muxc:InfoBar IsOpen="True"
                              IsClosable="True"
                              Severity="{Binding Severity, Converter={StaticResource SeverityToInfoBar}}"
                              Title="{Binding Title}"
                              Message="{Binding Message}"
                              Tag="{Binding Id}"
                              Closed="OnInfoBarClosed" />
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
