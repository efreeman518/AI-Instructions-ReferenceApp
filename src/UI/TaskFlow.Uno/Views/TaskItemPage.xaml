<Page x:Class="TaskFlow.Uno.Views.TaskItemPage"
      x:Name="TaskItemRoot"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uer="using:Uno.Extensions.Reactive.UI"
      Background="{ThemeResource BackgroundBrush}">

    <ScrollViewer>
        <utu:AutoLayout Spacing="20"
                        Padding="{utu:Responsive Normal='16,12,16,24', Wide='32,20,32,32'}"
                        MaxWidth="{StaticResource ContentMaxWidth}">

            <!-- Header with dynamic title + action buttons -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <utu:AutoLayout Spacing="4">
                    <TextBlock Text="{Binding FormHeader}" Style="{StaticResource TitleLarge}" />
                    <TextBlock Text="{Binding FormSubheader}"
                               Style="{StaticResource BodyMedium}"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                </utu:AutoLayout>
                <StackPanel Grid.Column="1"
                            Orientation="{utu:Responsive Normal=Vertical, Wide=Horizontal}"
                            Spacing="8" VerticalAlignment="Top">
                    <Button Content="{Binding SaveButtonText}" Command="{Binding Save}"
                            Style="{StaticResource FormActionButtonStyle}" />
                    <Button Content="Delete" Command="{Binding DeleteTask}"
                            Style="{StaticResource DangerButtonStyle}"
                            Visibility="{Binding IsEditMode}" />
                </StackPanel>
            </Grid>

            <!-- ═══════════ Task Details Form ═══════════ -->
            <Border Style="{StaticResource InlineFormCardStyle}">
                <utu:AutoLayout Spacing="16">
                    <TextBox Header="Title"
                             Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="What needs to be done?"
                             Style="{StaticResource FormTextBoxStyle}" />

                    <TextBox Header="Description"
                             Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="100"
                             PlaceholderText="Add details, context, or notes..."
                             Style="{StaticResource FormTextBoxStyle}" />

                    <!-- Narrow lists side-by-side when wide, stacked when narrow -->
                    <StackPanel Orientation="{utu:Responsive Normal=Vertical, Wide=Horizontal}"
                                Spacing="16">
                        <ComboBox Header="Priority" PlaceholderText="Select priority"
                                  SelectedItem="{Binding Priority, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  MinWidth="180">
                            <x:String>None</x:String>
                            <x:String>Low</x:String>
                            <x:String>Medium</x:String>
                            <x:String>High</x:String>
                            <x:String>Critical</x:String>
                        </ComboBox>

                        <ComboBox Header="Status" PlaceholderText="Select status"
                                  SelectedItem="{Binding Status, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  MinWidth="180">
                            <x:String>Open</x:String>
                            <x:String>InProgress</x:String>
                            <x:String>Completed</x:String>
                            <x:String>Blocked</x:String>
                            <x:String>Cancelled</x:String>
                        </ComboBox>

                        <ComboBox Header="Category" PlaceholderText="Select category"
                                  ItemsSource="{Binding Categories}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding SelectedCategoryId, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  MinWidth="180" />
                    </StackPanel>
                </utu:AutoLayout>
            </Border>

            <!-- ═══════════ Schedule ═══════════ -->
            <Border Style="{StaticResource InlineFormCardStyle}">
                <utu:AutoLayout Spacing="12">
                    <TextBlock Text="SCHEDULE" Style="{StaticResource StatLabelStyle}" />
                    <StackPanel Orientation="{utu:Responsive Normal=Vertical, Wide=Horizontal}"
                                Spacing="16">
                        <CalendarDatePicker Header="Start Date"
                                            Date="{Binding StartDate, Mode=TwoWay}"
                                            HorizontalAlignment="Stretch" MinWidth="200" />
                        <CalendarDatePicker Header="Due Date"
                                            Date="{Binding DueDate, Mode=TwoWay}"
                                            HorizontalAlignment="Stretch" MinWidth="200" />
                    </StackPanel>
                </utu:AutoLayout>
            </Border>

            <!-- ═══════════ Checklist Section ═══════════ -->
            <Border Style="{StaticResource InlineFormCardStyle}">
                <utu:AutoLayout Spacing="12">
                    <utu:AutoLayout Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE73A;" FontSize="20"
                                  Foreground="{ThemeResource PrimaryBrush}"
                                  utu:AutoLayout.CounterAlignment="Center" />
                        <TextBlock Text="Checklist"
                                   Style="{StaticResource TitleMedium}"
                                   Foreground="{ThemeResource OnSurfaceBrush}"
                                   utu:AutoLayout.CounterAlignment="Center" />
                    </utu:AutoLayout>

                    <ItemsControl ItemsSource="{Binding ChecklistItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="8" Padding="4,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsCompleted, Mode=OneWay}"
                                              Command="{Binding DataContext.ToggleChecklistItem, ElementName=TaskItemRoot}"
                                              CommandParameter="{Binding}" />
                                    <TextBlock Grid.Column="1" Text="{Binding Title}"
                                               Style="{StaticResource BodyMedium}"
                                               Foreground="{ThemeResource OnSurfaceBrush}"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="2" Content="&#xE74D;"
                                            FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14"
                                            Command="{Binding DataContext.DeleteChecklistItem, ElementName=TaskItemRoot}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" Padding="6"
                                            Foreground="{StaticResource AccentDangerBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox PlaceholderText="Add checklist item..."
                                 Text="{Binding NewChecklistTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBoxStyle}" />
                        <Button Grid.Column="1" Content="Add"
                                Command="{Binding AddChecklistItem}"
                                Style="{StaticResource FormActionButtonStyle}"
                                VerticalAlignment="Bottom" />
                    </Grid>
                </utu:AutoLayout>
            </Border>

            <!-- ═══════════ Comments Section ═══════════ -->
            <Border Style="{StaticResource InlineFormCardStyle}">
                <utu:AutoLayout Spacing="12">
                    <utu:AutoLayout Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE8F2;" FontSize="20"
                                  Foreground="{ThemeResource PrimaryBrush}"
                                  utu:AutoLayout.CounterAlignment="Center" />
                        <TextBlock Text="Comments"
                                   Style="{StaticResource TitleMedium}"
                                   Foreground="{ThemeResource OnSurfaceBrush}"
                                   utu:AutoLayout.CounterAlignment="Center" />
                    </utu:AutoLayout>

                    <ItemsControl ItemsSource="{Binding Comments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{ThemeResource SurfaceBrush}"
                                        CornerRadius="10"
                                        Padding="12,10"
                                        Margin="0,2">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xE77B;" FontSize="16"
                                                  Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                  VerticalAlignment="Top"
                                                  Margin="0,2,0,0" />
                                        <TextBlock Grid.Column="1" Text="{Binding Body}"
                                                   Style="{StaticResource BodyMedium}"
                                                   Foreground="{ThemeResource OnSurfaceBrush}"
                                                   TextWrapping="Wrap" />
                                        <Button Grid.Column="2" Content="&#xE74D;"
                                                FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14"
                                                Command="{Binding DataContext.DeleteComment, ElementName=TaskItemRoot}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" Padding="6"
                                                Foreground="{StaticResource AccentDangerBrush}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox PlaceholderText="Write a comment..."
                                 Text="{Binding NewCommentBody, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                                 Style="{StaticResource FormTextBoxStyle}" />
                        <Button Grid.Column="1" Content="Post"
                                Command="{Binding AddComment}"
                                Style="{StaticResource FormActionButtonStyle}"
                                VerticalAlignment="Bottom" />
                    </Grid>
                </utu:AutoLayout>
            </Border>

            <!-- ═══════════ Attachments Section ═══════════ -->
            <Border Style="{StaticResource InlineFormCardStyle}">
                <utu:AutoLayout Spacing="12">
                    <utu:AutoLayout Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE723;" FontSize="20"
                                  Foreground="{ThemeResource PrimaryBrush}"
                                  utu:AutoLayout.CounterAlignment="Center" />
                        <TextBlock Text="Attachments"
                                   Style="{StaticResource TitleMedium}"
                                   Foreground="{ThemeResource OnSurfaceBrush}"
                                   utu:AutoLayout.CounterAlignment="Center" />
                    </utu:AutoLayout>

                    <ItemsControl ItemsSource="{Binding Attachments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{ThemeResource SurfaceBrush}"
                                        CornerRadius="10"
                                        Padding="12,8"
                                        Margin="0,2">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xE7C3;" FontSize="16"
                                                  Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                  VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding FileName}"
                                                   Style="{StaticResource BodyMedium}"
                                                   Foreground="{ThemeResource OnSurfaceBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding ContentType}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </utu:AutoLayout>
            </Border>

        </utu:AutoLayout>
    </ScrollViewer>
</Page>
