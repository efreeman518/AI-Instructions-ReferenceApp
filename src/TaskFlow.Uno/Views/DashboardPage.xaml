<Page x:Class="TaskFlow.Uno.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI">

    <Grid Padding="24">
        <ScrollViewer>
            <StackPanel Spacing="16">
                <TextBlock Text="Dashboard" Style="{StaticResource TitleLargeTextBlockStyle}" />

                <!-- Summary Cards -->
                <Grid ColumnSpacing="12" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <utu:Card Grid.Column="0" Grid.Row="0">
                        <StackPanel Padding="16" Spacing="4">
                            <TextBlock Text="Total Tasks" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="{Binding Summary.TotalTasks}" Style="{StaticResource TitleLargeTextBlockStyle}" />
                        </StackPanel>
                    </utu:Card>

                    <utu:Card Grid.Column="1" Grid.Row="0">
                        <StackPanel Padding="16" Spacing="4">
                            <TextBlock Text="Open" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="{Binding Summary.OpenTasks}" Style="{StaticResource TitleLargeTextBlockStyle}" />
                        </StackPanel>
                    </utu:Card>

                    <utu:Card Grid.Column="2" Grid.Row="0">
                        <StackPanel Padding="16" Spacing="4">
                            <TextBlock Text="In Progress" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="{Binding Summary.InProgressTasks}" Style="{StaticResource TitleLargeTextBlockStyle}" />
                        </StackPanel>
                    </utu:Card>

                    <utu:Card Grid.Column="0" Grid.Row="1">
                        <StackPanel Padding="16" Spacing="4">
                            <TextBlock Text="Completed" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="{Binding Summary.CompletedTasks}" Style="{StaticResource TitleLargeTextBlockStyle}" />
                        </StackPanel>
                    </utu:Card>

                    <utu:Card Grid.Column="1" Grid.Row="1">
                        <StackPanel Padding="16" Spacing="4">
                            <TextBlock Text="Blocked" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="Orange" />
                            <TextBlock Text="{Binding Summary.BlockedTasks}" Style="{StaticResource TitleLargeTextBlockStyle}" />
                        </StackPanel>
                    </utu:Card>

                    <utu:Card Grid.Column="2" Grid.Row="1">
                        <StackPanel Padding="16" Spacing="4">
                            <TextBlock Text="Overdue" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="Red" />
                            <TextBlock Text="{Binding Summary.OverdueTasks}" Style="{StaticResource TitleLargeTextBlockStyle}" />
                        </StackPanel>
                    </utu:Card>
                </Grid>

                <!-- Recent Activity -->
                <TextBlock Text="Recent Activity" Style="{StaticResource TitleTextBlockStyle}" Margin="0,16,0,0" />

                <ListView ItemsSource="{Binding Summary.RecentActivity}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Title}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Status}" Opacity="0.7" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{Binding Priority}" Opacity="0.7" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Button Content="View All Tasks"
                        Command="{Binding NavigateToTaskList}"
                        Style="{StaticResource FilledButtonStyle}"
                        HorizontalAlignment="Center" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
