<Page x:Class="TaskFlow.Uno.Views.TaskFormPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI">

    <Grid Padding="24">
        <ScrollViewer>
            <StackPanel Spacing="16" MaxWidth="600">
                <TextBlock Text="Task" Style="{StaticResource TitleLargeTextBlockStyle}" />

                <TextBox Header="Title" Text="{Binding Title, Mode=TwoWay}" PlaceholderText="Enter task title" />

                <TextBox Header="Description" Text="{Binding Description, Mode=TwoWay}"
                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="100"
                         PlaceholderText="Enter description" />

                <ComboBox Header="Priority" PlaceholderText="Select priority" Width="200">
                    <ComboBoxItem Content="None" />
                    <ComboBoxItem Content="Low" />
                    <ComboBoxItem Content="Medium" />
                    <ComboBoxItem Content="High" />
                    <ComboBoxItem Content="Critical" />
                </ComboBox>

                <CalendarDatePicker Header="Start Date" />

                <CalendarDatePicker Header="Due Date" />

                <ComboBox Header="Category"
                          ItemsSource="{Binding Categories}"
                          DisplayMemberPath="Name"
                          PlaceholderText="Select category" />

                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" Margin="0,24,0,0">
                    <Button Content="Cancel" Command="{Binding Cancel}" />
                    <Button Content="Save" Command="{Binding Save}" Style="{StaticResource FilledButtonStyle}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
