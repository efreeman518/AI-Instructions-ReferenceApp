<Page x:Class="TaskFlow.Uno.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI">

    <Grid Padding="24">
        <StackPanel Spacing="24" MaxWidth="500">
            <TextBlock Text="Settings" Style="{StaticResource TitleLargeTextBlockStyle}" />

            <utu:Card>
                <StackPanel Padding="16" Spacing="12">
                    <TextBlock Text="API Configuration" Style="{StaticResource TitleTextBlockStyle}" />

                    <TextBox Header="Gateway URL" Text="{Binding GatewayUrl, Mode=TwoWay}" />

                    <ToggleSwitch Header="Use Mock Data" IsOn="{Binding UseMocks, Mode=TwoWay}" />
                </StackPanel>
            </utu:Card>

            <utu:Card>
                <StackPanel Padding="16" Spacing="12">
                    <TextBlock Text="About" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock Text="TaskFlow v1.0" />
                    <TextBlock Text="Built with Uno Platform + .NET 10" Opacity="0.6" />
                </StackPanel>
            </utu:Card>

            <Button Content="Back"
                    Command="{Binding NavigateBack}"
                    HorizontalAlignment="Left" />
        </StackPanel>
    </Grid>
</Page>
