<Page x:Class="TaskFlow.Uno.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI">

    <Grid>
        <NavigationView x:Name="NavView"
                        PaneDisplayMode="Left"
                        IsBackButtonVisible="Collapsed"
                        uen:Navigation.Request="Dashboard">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Dashboard"
                                    uen:Navigation.Request="Dashboard"
                                    Icon="Home" />
                <NavigationViewItem Content="Tasks"
                                    uen:Navigation.Request="TaskList"
                                    Icon="AllApps" />
                <NavigationViewItem Content="Categories"
                                    uen:Navigation.Request="Categories"
                                    Icon="Library" />
                <NavigationViewItem Content="Tags"
                                    uen:Navigation.Request="Tags"
                                    Icon="Tag" />
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Settings"
                                    uen:Navigation.Request="Settings"
                                    Icon="Setting" />
            </NavigationView.FooterMenuItems>

            <Grid uen:Region.Attached="true">
                <Frame />
            </Grid>
        </NavigationView>
    </Grid>
</Page>
