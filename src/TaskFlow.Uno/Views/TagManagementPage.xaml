<Page x:Class="TaskFlow.Uno.Views.TagManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Tags" Style="{StaticResource TitleLargeTextBlockStyle}" />

        <!-- Create Form -->
        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" PlaceholderText="Tag name" Text="{Binding NewTagName, Mode=TwoWay}" />
            <TextBox Grid.Column="1" PlaceholderText="Color (#hex)" Text="{Binding NewTagColor, Mode=TwoWay}" Width="120" />
            <Button Grid.Column="2" Content="Add" Command="{Binding CreateTag}" Style="{StaticResource FilledButtonStyle}" />
        </Grid>

        <!-- Tag List -->
        <ListView Grid.Row="2" ItemsSource="{Binding Tags}" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="12" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="16" Height="16" CornerRadius="8"
                                Background="{Binding Color}" />

                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />

                        <Button Grid.Column="2" Content="Edit"
                                Command="{Binding DataContext.StartEdit, ElementName=TagManagementPage}"
                                CommandParameter="{Binding}" />

                        <Button Grid.Column="3" Content="✕"
                                Command="{Binding DataContext.DeleteTag, ElementName=TagManagementPage}"
                                CommandParameter="{Binding}" Foreground="Red" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
