  <ItemGroup Label="Azure Service Bus">
    <PackageVersion Include="Azure.Messaging.ServiceBus" Version="7.20.1" />
    <PackageVersion Include="Aspire.Hosting.Azure.ServiceBus" Version="13.4.6" />
  </ItemGroup>
  <ItemGroup Label="Azure Cosmos DB">
    <PackageVersion Include="Microsoft.Azure.Cosmos" Version="3.61.0" />
    <PackageVersion Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageVersion Include="Aspire.Hosting.Azure.CosmosDB" Version="13.4.6" />
  </ItemGroup>
  <ItemGroup Label="Data Protection">
    <PackageVersion Include="Azure.Extensions.AspNetCore.DataProtection.Blobs" Version="1.5.3" />
    <PackageVersion Include="Azure.Extensions.AspNetCore.DataProtection.Keys" Version="1.6.3" />
  </ItemGroup>
  <ItemGroup Label="AI Services">
    <PackageVersion Include="Azure.AI.OpenAI" Version="2.9.0-beta.1" />
    <PackageVersion Include="Azure.Identity" Version="1.21.0" />
    <!-- Always Encrypted CMK provider (D-019); pinned to match EF.Data 1.0.88's transitive dependency. -->
    <PackageVersion Include="Microsoft.Data.SqlClient.AlwaysEncrypted.AzureKeyVaultProvider" Version="7.0.2" />
    <PackageVersion Include="Azure.Search.Documents" Version="12.0.0" />
    <PackageVersion Include="Microsoft.Agents.AI" Version="1.11.1" />
    <PackageVersion Include="Microsoft.Agents.AI.OpenAI" Version="1.11.1" />
    <PackageVersion Include="Microsoft.Extensions.AI" Version="10.7.0" />
    <PackageVersion Include="Microsoft.Extensions.AI.OpenAI" Version="10.7.0" />
    <!-- Pinned: workaround for Aspire.Hosting.Foundry using an older Foundry Local SDK that cannot discover the GA 1.x runtime. Remove with API-host SDK-direct workaround. -->
    <PackageVersion Include="Microsoft.AI.Foundry.Local" Version="1.2.3" />
    <PackageVersion Include="OpenAI" Version="2.11.0" />
    <PackageVersion Include="Aspire.Hosting.Azure.CognitiveServices" Version="13.4.6" />
    <PackageVersion Include="Aspire.Hosting.Azure.Search" Version="13.4.6" />
    <PackageVersion Include="Aspire.Hosting.Testing" Version="13.4.6" />
    <!-- Foundry hosting + Azure AI Inference client are preview-only; keep them on the latest 13.4.5 Aspire train with the other Aspire packages. -->
    <PackageVersion Include="Aspire.Hosting.Foundry" Version="13.4.5-preview.1.26316.12" />
    <PackageVersion Include="Aspire.Azure.AI.Inference" Version="13.4.5-preview.1.26316.12" />
  </ItemGroup>
</Project>
