  <ItemGroup Label="Caching">
    <PackageVersion Include="ZiggyCreatures.FusionCache" Version="2.6.0" />
    <PackageVersion Include="ZiggyCreatures.FusionCache.Serialization.SystemTextJson" Version="2.6.0" />
    <PackageVersion Include="ZiggyCreatures.FusionCache.Backplane.StackExchangeRedis" Version="2.6.0" />
    <PackageVersion Include="Microsoft.Extensions.Caching.StackExchangeRedis" Version="10.0.9" />
  </ItemGroup>
  <ItemGroup Label="Testing">
    <PackageVersion Include="MSTest" Version="4.2.3" />
    <PackageVersion Include="Microsoft.NET.Test.Sdk" Version="18.7.0" />
    <PackageVersion Include="Microsoft.Playwright" Version="1.61.0" />
    <PackageVersion Include="Appium.WebDriver" Version="8.3.0" />
    <PackageVersion Include="Moq" Version="4.20.72" />
    <PackageVersion Include="NetArchTest.Rules" Version="1.3.2" />
    <PackageVersion Include="NBomber" Version="6.5.0" />
    <PackageVersion Include="NBomber.Http" Version="6.2.0" />
    <PackageVersion Include="BenchmarkDotNet" Version="0.15.8" />
  </ItemGroup>
  <ItemGroup Label="UI">
    <PackageVersion Include="CommunityToolkit.Mvvm" Version="8.4.2" />
    <PackageVersion Include="MudBlazor" Version="9.6.0" />
    <PackageVersion Include="Refit" Version="12.1.0" />
    <PackageVersion Include="Refit.HttpClientFactory" Version="12.1.0" />
    <PackageVersion Include="Microsoft.Kiota.Abstractions" Version="2.0.0" />
    <PackageVersion Include="Uno.Extensions.Navigation" Version="7.1.4" />
    <PackageVersion Include="Uno.Extensions.Navigation.WinUI" Version="7.1.4" />
    <PackageVersion Include="Uno.Extensions.Reactive" Version="7.1.4" />
  </ItemGroup>
  <ItemGroup Label="Security transitive overrides">
    <!-- Temporary direct pin: lifts a vulnerable transitive of NBomber (NU1903) above the version
         it resolves. Remove when NBomber ships a fixed dependency and the audit is clean. -->
    <PackageVersion Include="MessagePack" Version="3.1.7" />
    <!-- Temporary direct pin: lifts a vulnerable transitive of Microsoft.AspNetCore.OpenApi (NU1903,
         GHSA-v5pm-xwqc-g5wc) above the version it resolves. Remove when Microsoft.AspNetCore.OpenApi
         ships a fixed dependency and the audit is clean. -->
    <PackageVersion Include="Microsoft.OpenApi" Version="2.9.0" />
    <!-- Temporary direct pin: lifts a vulnerable transitive of the Uno toolchain above the version
         it resolves. Remove when the parent ships a fixed dependency and the audit is clean. -->
    <PackageVersion Include="System.Security.Cryptography.Xml" Version="10.0.9" />
  </ItemGroup>
  <ItemGroup Label="Azure Storage">
    <PackageVersion Include="Azure.Data.Tables" Version="12.11.0" />
    <PackageVersion Include="Azure.Storage.Blobs" Version="12.29.1" />
    <PackageVersion Include="Microsoft.Extensions.Azure" Version="1.14.0" />
    <PackageVersion Include="Aspire.Hosting.Azure.Storage" Version="13.4.6" />
